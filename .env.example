# ── Laravel backend ──────────────────────────────────────
APP_NAME="Forge2 Kanban"
APP_ENV=local
APP_KEY=                      # generate with: php artisan key:generate
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# ── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# ── Slack (Hermes + OpenClaw) ────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...      # required for socket mode
SLACK_WORKSPACE=forge-02-kapil
SLACK_CHANNEL_SPRINT_MAIN=#sprint-main
SLACK_CHANNEL_AGENT_LOG=#agent-log
SLACK_CHANNEL_ORCHESTRATOR=#agent-orchestrator
SLACK_CHANNEL_HUMAN_REVIEW=#human-review

# ── Hermes (planning agent) ──────────────────────────────
HERMES_MODEL=qwen3.5:9b
HERMES_OLLAMA_HOST=http://localhost:11434
HERMES_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# ── OpenClaw (execution agent) ───────────────────────────
OPENCLAW_MODEL=ollama/gemma4:31b
OPENCLAW_OLLAMA_CLOUD_HOST=
OPENCLAW_OLLAMA_CLOUD_API_KEY=
